# AgriHA v4 環境変数設定
# このファイルを .env にコピーして値を記入:
#   cp /opt/agriha/.env.example /opt/agriha/.env
#   nano /opt/agriha/.env

# === オプション（APIキーを入力するとクラウドLLMが有効になります）===
# Claude Haiku API キー（入力しなくてもNullClawで動作します）
# export ANTHROPIC_API_KEY=sk-ant-xxxx

# Weather API (Visual Crossing: forecast_engine.py)
# https://www.visualcrossing.com/account
export VC_API_KEY=your_api_key_here

# === LINE Bot (VPS only, not needed on RPi) ===
# https://developers.line.biz/console/
export LINE_CHANNEL_SECRET=
export LINE_CHANNEL_ACCESS_TOKEN=
export LINE_USER_ID=

# === オプション（デフォルト値あり）===
# NullClaw OpenAI互換プロキシ設定（デフォルト値で動作）
# export NULLCLAW_BASE_URL=http://localhost:3001/v1/
# export NULLCLAW_TIMEOUT=25
# UNIPI_API_URL=http://localhost:8080
# UI_AUTH_USER=admin
# UI_AUTH_PASS=agriha
# SYSTEM_PROMPT_PATH=/etc/agriha/system_prompt.txt
# AGRIHA_THRESHOLDS_PATH=/etc/agriha/thresholds.yaml
# CONTROL_LOG_DB=/var/lib/agriha/control_log.db
