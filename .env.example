# AgriHA environment variables
# Copy to .env and fill in values:
#   cp /opt/agriha/.env.example /opt/agriha/.env
#   nano /opt/agriha/.env
#
# NOTE: Do NOT use "export" prefix. systemd EnvironmentFile requires KEY=VALUE format.

# === Optional (cloud LLM enabled when API key is set) ===
# Claude Haiku API key (NullClaw works without it)
# ANTHROPIC_API_KEY=sk-ant-xxxx

# Weather API (Visual Crossing: forecast_engine.py)
# https://www.visualcrossing.com/account
VC_API_KEY=your_api_key_here

# === LINE Bot ===
# https://developers.line.biz/console/
# Webhook URL: https://your_domain/callback (set in LINE Developers Console)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# === Optional (defaults provided) ===
# NullClaw OpenAI-compatible proxy (works with defaults)
# NULLCLAW_BASE_URL=http://localhost:3001/v1/
# NULLCLAW_TIMEOUT=25
# UNIPI_API_URL=http://localhost:8080
# UI_AUTH_USER=admin
# UI_AUTH_PASS=agriha
# SYSTEM_PROMPT_PATH=/etc/agriha/system_prompt.txt
# AGRIHA_THRESHOLDS_PATH=/etc/agriha/thresholds.yaml
# CONTROL_LOG_DB=/var/lib/agriha/control_log.db
