# AgriHA v4 環境変数設定
# このファイルを .env にコピーして値を記入:
#   cp /opt/agriha/.env.example /opt/agriha/.env
#   nano /opt/agriha/.env

# === 必須 ===
# Claude Haiku API キー（Layer 3 LLM予報制御用）
ANTHROPIC_API_KEY=sk-ant-xxxx

# Weather API（Visual Crossing 天気予報: forecast_engine.py）
VC_API_KEY=your_api_key_here

# === LINE Bot（VPS用、RPiでは不要）===
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=

# === オプション（デフォルト値あり）===
# UNIPI_API_URL=http://localhost:8080
# UI_AUTH_USER=admin
# UI_AUTH_PASS=agriha
# SYSTEM_PROMPT_PATH=/etc/agriha/system_prompt.txt
# AGRIHA_THRESHOLDS_PATH=/etc/agriha/thresholds.yaml
# CONTROL_LOG_DB=/var/lib/agriha/control_log.db
