# /etc/nginx/sites-available/__DOMAIN__
# VPS nginx設定 — LINE Bot webhook + QR画像配信
#
# このファイルはテンプレート。deploy_vps_linebot.sh --setup が
# config/vps.conf の値で置換して配置する。手動編集不要。

# HTTP → HTTPS リダイレクト
server {
    listen 80;
    server_name __DOMAIN__;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name __DOMAIN__;

    # Let's Encrypt 証明書（certbot管理）
    ssl_certificate     __SSL_CERT__;
    ssl_certificate_key __SSL_KEY__;

    # SSL設定
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # --- LINE Bot webhook ---
    location /callback {
        proxy_pass http://127.0.0.1:__APP_PORT__;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /callback/test {
        proxy_pass http://127.0.0.1:__APP_PORT__;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # --- 内部API（register_pubkey, cleanup_qr等）---
    location /api/ {
        proxy_pass http://127.0.0.1:__APP_PORT__;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # --- QR画像配信（静的ファイル）---
    location /qr/ {
        alias __QR_DIR__/;
        expires 24h;
        add_header Cache-Control "public, no-transform";
    }

    # --- ヘルスチェック ---
    location /health {
        proxy_pass http://127.0.0.1:__APP_PORT__;
        proxy_set_header Host $host;
    }

    # certbot チャレンジ
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }
}
