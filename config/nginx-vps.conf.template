# /etc/nginx/sites-available/__DOMAIN__
# VPS nginx config -- LINE Bot webhook + QR image serving
#
# This is a template. deploy_vps_linebot.sh --setup expands
# placeholders from config/vps.conf. Do not edit manually.

# HTTP -> HTTPS redirect
server {
    listen 80;
    server_name __DOMAIN__;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name __DOMAIN__;

    # Let's Encrypt certificates (managed by certbot)
    ssl_certificate     __SSL_CERT__;
    ssl_certificate_key __SSL_KEY__;

    # SSL settings
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # --- LINE Bot webhook ---
    location /callback {
        proxy_pass http://127.0.0.1:__APP_PORT__;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /callback/test {
        proxy_pass http://127.0.0.1:__APP_PORT__;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # --- Internal API (register_pubkey, cleanup_qr, etc.) ---
    location /api/ {
        proxy_pass http://127.0.0.1:__APP_PORT__;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # --- QR image serving (static files) ---
    location /qr/ {
        alias __QR_DIR__/;
        expires 24h;
        add_header Cache-Control "public, no-transform";
    }

    # --- Health check ---
    location /health {
        proxy_pass http://127.0.0.1:__APP_PORT__;
        proxy_set_header Host $host;
    }

    # certbot challenge
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }
}
