# config/farmers_secrets.yaml - 農家秘密情報（.gitignore対象）
# このファイルを config/farmers_secrets.yaml にコピーして使用:
#   cp config/farmers_secrets.yaml.example config/farmers_secrets.yaml
#   chmod 600 config/farmers_secrets.yaml
#
# ⚠️ このファイルは git管理しない。.gitignore に登録済み。
# ⚠️ wg_client_private_key は保存しない。
#    農家RPiの秘密鍵はRPiローカルのみ保持。再セットアップ時はwg genkeyで再生成。
#
# 設計書: docs/multi_farmer_design.md §8

farmers:
  # ─────────────────────────────────────────
  # Phase 0: 殿のみ
  # ─────────────────────────────────────────
  tono:
    line_user_id: "U1234567890abcdef"   # LINE follow event時に自動設定
    wg_public_key: "aBcDeFgHiJkLmNo="  # RPiから POST /api/register_pubkey で受信
    wg_ip: "10.20.0.10"
    status: active

  # ─────────────────────────────────────────
  # Phase 1以降
  # ─────────────────────────────────────────
  farmer_a:
    line_user_id: "Uabcdef1234567890"
    wg_public_key: "zYxWvUtSrQpOnMlK="  # RPiから受信した公開鍵（秘密鍵ではない）
    wg_ip: "10.20.0.10"
    status: active

  farmer_b:
    line_user_id: ""                    # follow event受信後に設定
    wg_public_key: ""                   # RPi登録後に設定
    wg_ip: "10.20.0.20"
    status: pending

# ─────────────────────────────────────────
# 秘密鍵保持ポリシー
# ─────────────────────────────────────────
# ✅ 保存するもの: line_user_id, wg_public_key (公開鍵), wg_ip
# ❌ 保存しないもの: wg_client_private_key (秘密鍵)
#
# 理由:
#   - 秘密鍵はLINE経由で送信しない（LINEはE2E暗号化なし）
#   - 秘密鍵はRPiローカルに閉じることでセキュリティを確保
#   - RPi再セットアップ時: wg genkey で再生成 → MBPのPeer公開鍵を更新
#
# MBP公開鍵更新コマンド（RPi再セットアップ後）:
#   sudo wg set wg-farmers peer <新しいRPi_PUBLIC_KEY> allowed-ips 10.20.0.N/32
