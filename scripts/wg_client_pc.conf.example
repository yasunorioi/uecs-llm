# =============================================================================
# WireGuard Client Configuration - Development PC
# =============================================================================
#
# This is a template configuration file for the development PC.
#
# SETUP INSTRUCTIONS:
#
# Windows:
#   1. Download WireGuard from https://www.wireguard.com/install/
#   2. Open WireGuard application
#   3. Click "Add Tunnel" > "Add empty tunnel..."
#   4. Paste this configuration (with your actual keys)
#   5. Click "Activate"
#
# macOS:
#   1. Install from App Store or: brew install wireguard-tools
#   2. Open WireGuard application
#   3. Click "+" > "Add Empty Tunnel..."
#   4. Paste this configuration (with your actual keys)
#   5. Click "Activate"
#
# Linux:
#   1. Install: sudo apt install wireguard wireguard-tools
#   2. Copy this file to /etc/wireguard/wg0.conf
#   3. Edit with your actual keys
#   4. Start: sudo wg-quick up wg0
#   5. Enable on boot: sudo systemctl enable wg-quick@wg0
#
# =============================================================================

[Interface]
# Development PC's VPN IP address
Address = 10.10.0.100/24

# Your private key (generated by server setup script)
# IMPORTANT: Keep this secret! Never share your private key.
PrivateKey = YOUR_DEVPC_PRIVATE_KEY

# Optional: Use custom DNS servers when VPN is active
# Uncomment the line below if you want to use specific DNS servers
# DNS = 1.1.1.1, 8.8.8.8

[Peer]
# Sakura Cloud VPS server's public key
PublicKey = YOUR_SERVER_PUBLIC_KEY

# Preshared key for additional security (optional but recommended)
PresharedKey = YOUR_PRESHARED_KEY

# Server's public IP and WireGuard port
# Replace YOUR_SERVER_IP with your Sakura Cloud VPS's actual IP
Endpoint = YOUR_SERVER_IP:51820

# Which IPs should be routed through the VPN
# Option 1: Only VPN subnet (split tunnel - recommended)
AllowedIPs = 10.10.0.0/24

# Option 2: All traffic through VPN (full tunnel)
# AllowedIPs = 0.0.0.0/0, ::/0

# Keep connection alive (important if behind NAT/firewall)
# Sends a keepalive packet every 25 seconds
PersistentKeepalive = 25


# =============================================================================
# NETWORK TOPOLOGY
# =============================================================================
#
#   Development PC (10.10.0.100)
#         |
#         | WireGuard VPN
#         |
#   Sakura Cloud VPS (10.10.0.1) <-- Public IP: YOUR_SERVER_IP
#         |
#         | WireGuard VPN
#         |
#   Arsprout Pi (10.10.0.10) <-- Behind Starlink NAT
#
# =============================================================================
# USEFUL COMMANDS
# =============================================================================
#
# Check VPN status:
#   wg show
#
# Ping the server:
#   ping 10.10.0.1
#
# Ping Arsprout:
#   ping 10.10.0.10
#
# SSH to Arsprout through VPN:
#   ssh pi@10.10.0.10
#
# Stop VPN (Linux):
#   sudo wg-quick down wg0
#
# View logs (Linux):
#   sudo journalctl -u wg-quick@wg0
#
# =============================================================================
# TROUBLESHOOTING
# =============================================================================
#
# 1. Cannot connect to server
#    - Check if server's firewall allows UDP 51820
#    - Verify Endpoint IP is correct
#    - Try: ping YOUR_SERVER_IP
#
# 2. Can ping server but not Arsprout
#    - Arsprout may be offline or misconfigured
#    - Check: ssh to server, then run 'wg show' to see peer status
#
# 3. Handshake timeout
#    - Verify public keys are correct on both ends
#    - Check if PresharedKey matches
#
# 4. Works initially but disconnects
#    - Ensure PersistentKeepalive is set
#    - Check if your firewall drops UDP connections
#
# =============================================================================
