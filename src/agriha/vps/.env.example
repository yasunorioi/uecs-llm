# LINE Developer Console credentials
# https://developers.line.biz/console/
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Test channel settings (for /callback/test endpoint)
LINE_CHANNEL_SECRET_TEST=your_test_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN_TEST=your_test_channel_access_token_here

# RPi forwarding (via WireGuard VPN)
# All messages are forwarded to RPi agriha_chat.py. LLM selection is on RPi side.
RPI_CHAT_TIMEOUT=30

# WireGuard farmer VPN settings
# Set public key after running wg_farmers_vps_setup.sh
WG_SERVER_PUBLIC_KEY=your_wg_public_key_here
WG_SERVER_ENDPOINT=your_vps_ip:51821
MBP_API_ENDPOINT=http://10.20.0.1:5000
WG_CONF_PATH=/etc/wireguard/wg-farmers.conf
CONFIG_DIR=/opt/agriha-linebot/config

# QR image serving settings
# Must match DOMAIN and QR_DIR in config/vps.conf
QR_DIR=/var/www/qr
QR_BASE_URL=https://your_domain_here/qr
