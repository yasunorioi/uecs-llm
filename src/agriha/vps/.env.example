# LINE Developer Console から取得
# https://developers.line.biz/console/
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# テストチャネル設定（/callback/test エンドポイント用）
LINE_CHANNEL_SECRET_TEST=your_test_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN_TEST=your_test_channel_access_token_here

# RPi転送設定（WireGuard VPN経由）
# メッセージは全てRPi agriha_chat.py に転送。LLM選択はRPi側で行う。
RPI_CHAT_TIMEOUT=30

# WireGuard 農家VPN設定
WG_SERVER_PUBLIC_KEY=your_wg_public_key_here
WG_SERVER_ENDPOINT=153.127.46.167:51821
MBP_API_ENDPOINT=http://10.20.0.1:5000
WG_CONF_PATH=/etc/wireguard/wg-farmers.conf
CONFIG_DIR=/opt/agriha-linebot/config

# QR画像配信設定
QR_DIR=/var/www/qr
QR_BASE_URL=https://toiso.fit/qr
