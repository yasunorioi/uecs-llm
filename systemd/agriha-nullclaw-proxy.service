[Unit]
Description=NullClaw OpenAI-Compatible Proxy
After=network.target

[Service]
Type=simple
User=agriha
ExecStart=/opt/agriha/venv/bin/uvicorn agriha.control.nullclaw_proxy:app --host 127.0.0.1 --port 3001
Restart=always
RestartSec=5
EnvironmentFile=/opt/agriha/.env

[Install]
WantedBy=multi-user.target
